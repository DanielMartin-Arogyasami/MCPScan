{
  "name": "mcpscan",
  "version": "1.0.0",
  "description": "Security scanner for MCP (Model Context Protocol) servers — like npm audit for AI agent tool integrations",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcpscan": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup src/cli.ts src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "scan": "tsx src/cli.ts",
    "scan:test": "tsx test-servers/run-test.ts",
    "scan:batch": "tsx src/registry/batch-scan.ts",
    "scan:npm": "tsx src/registry/scraper.ts",
    "scan:npm:dry": "tsx src/registry/scraper.ts --dry-run"
  },
  "keywords": [
    "mcp",
    "security",
    "scanner",
    "model-context-protocol",
    "ai",
    "agent",
    "vulnerability",
    "audit"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
